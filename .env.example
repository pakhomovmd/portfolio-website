# Resend API Key для отправки email через форму контактов
# Получить бесплатный API ключ можно на https://resend.com
# 1. Зарегистрируйтесь на resend.com
# 2. Создайте API ключ в разделе API Keys
# 3. Скопируйте ключ и вставьте сюда
RESEND_API_KEY=ВАШ_КЛЮЧ
# Email для получения сообщений с формы контактов
CONTACT_EMAIL=pakhomovmichael@icloud.com

# Примечание: Без RESEND_API_KEY форма будет работать, 
# но сообщения будут только логироваться в консоль сервера
